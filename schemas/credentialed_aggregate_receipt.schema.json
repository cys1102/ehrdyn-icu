{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cys1102/ehrdyn-icu/schemas/credentialed_aggregate_receipt.schema.json",
  "title": "Current five-task credentialed aggregate receipt candidate",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release", "candidate_status", "source_hashes", "runtime", "contracts", "streaming", "tasks", "privacy"],
  "properties": {
    "schema_version": {"const": "1.2.0"},
    "release": {"const": "MIMIC-IV-3.1"},
    "candidate_status": {"const": "credentialed_parity_pending"},
    "source_hashes": {
      "type": "object",
      "additionalProperties": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["python", "numpy", "pandas", "timezone", "locale"],
      "properties": {
        "python": {"type": "string", "pattern": "^3\\.(11|12|13)\\."},
        "numpy": {"type": "string"},
        "pandas": {"type": "string"},
        "timezone": {"const": "UTC"},
        "locale": {"type": "string"}
      }
    },
    "contracts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["feature_order_sha256", "role_assignment_sha256", "scientific_surface_sha256", "bin_hours", "pre_anchor_hours", "post_anchor_hours", "episode_window_hours", "episode_bins", "raw_extraction_post_base_anchor_hours", "sepsis_max_base_to_final_anchor_shift_hours", "longest_recursive_target_hours"],
      "properties": {
        "feature_order_sha256": {"$ref": "#/$defs/sha256"},
        "role_assignment_sha256": {"$ref": "#/$defs/sha256"},
        "scientific_surface_sha256": {"$ref": "#/$defs/sha256"},
        "bin_hours": {"const": 4},
        "pre_anchor_hours": {"const": 24},
        "post_anchor_hours": {"const": 48},
        "episode_window_hours": {"const": 72},
        "episode_bins": {"const": 18},
        "raw_extraction_post_base_anchor_hours": {"const": 96},
        "sepsis_max_base_to_final_anchor_shift_hours": {"const": 48},
        "longest_recursive_target_hours": {"const": 44}
      }
    },
    "streaming": {
      "type": "array",
      "minItems": 7,
      "maxItems": 7,
      "prefixItems": [
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "hosp/labevents"}}}]},
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "hosp/microbiologyevents"}}}]},
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "hosp/prescriptions"}}}]},
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "icu/chartevents"}}}]},
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "icu/inputevents"}}}]},
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "icu/outputevents"}}}]},
        {"allOf": [{"$ref": "#/$defs/streaming_row"}, {"properties": {"table": {"const": "icu/procedureevents"}}}]}
      ],
      "items": false
    },
    "tasks": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "prefixItems": [
        {"$ref": "#/$defs/sepsis"},
        {"$ref": "#/$defs/respiratory"},
        {"$ref": "#/$defs/shock"},
        {"$ref": "#/$defs/aki"},
        {"$ref": "#/$defs/heart_failure"}
      ],
      "items": false
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate_only", "subgroup_cells_exported", "row_level_fields_exported"],
      "properties": {
        "aggregate_only": {"const": true},
        "subgroup_cells_exported": {"const": false},
        "row_level_fields_exported": {"const": false}
      }
    }
  },
  "$defs": {
    "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "streaming_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table", "rows_read", "rows_retained", "chunks_processed", "maximum_retained_rows_per_chunk", "effective_chunk_size", "compression_encoding", "scan_count"],
      "properties": {
        "table": {"type": "string"},
        "rows_read": {"type": "integer", "minimum": 0},
        "rows_retained": {"type": "integer", "minimum": 0},
        "chunks_processed": {"type": "integer", "minimum": 0},
        "maximum_retained_rows_per_chunk": {"type": "integer", "minimum": 0},
        "effective_chunk_size": {"type": "integer", "minimum": 1},
        "compression_encoding": {"enum": ["csv", "csv_gz"]},
        "scan_count": {"type": "integer", "minimum": 1}
      }
    },
    "task": {
      "type": "object",
      "additionalProperties": false,
      "required": ["task_id", "subjects", "episodes", "decisions", "action_counts", "minimum_horizon", "maximum_horizon", "action_count", "cutpoints", "cutpoint_hash", "support_mask_digest", "transition_stages", "role_summaries", "reward_contract", "reward_observed_decisions", "terminal_reward_count"],
      "properties": {
        "task_id": {"type": "string"},
        "subjects": {"type": "integer", "minimum": 0},
        "episodes": {"type": "integer", "minimum": 0},
        "decisions": {"type": "integer", "minimum": 0},
        "action_counts": {"type": "array", "items": {"type": "integer", "minimum": 0}},
        "minimum_horizon": {"type": "integer", "minimum": 0},
        "maximum_horizon": {"type": "integer", "minimum": 0},
        "action_count": {"type": "integer"},
        "cutpoints": {"type": "array", "items": {"type": "array", "items": {"type": "number"}}},
        "cutpoint_hash": {"$ref": "#/$defs/sha256"},
        "support_mask_digest": {"$ref": "#/$defs/sha256"},
        "transition_stages": {"$ref": "#/$defs/transition_stages"},
        "role_summaries": {
          "type": "array", "minItems": 4, "maxItems": 4,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/role_summary"}, {"properties": {"role": {"const": "train"}}}]},
            {"allOf": [{"$ref": "#/$defs/role_summary"}, {"properties": {"role": {"const": "validation"}}}]},
            {"allOf": [{"$ref": "#/$defs/role_summary"}, {"properties": {"role": {"const": "historical_other"}}}]},
            {"allOf": [{"$ref": "#/$defs/role_summary"}, {"properties": {"role": {"const": "all_roles"}}}]}
          ], "items": false
        },
        "reward_contract": {"type": "string"},
        "reward_observed_decisions": {"type": "integer", "minimum": 0},
        "terminal_reward_count": {"type": "integer", "minimum": 0}
      }
    },
    "transition_stages": {
      "type": "object", "additionalProperties": false,
      "required": ["candidate_transitions", "original_target_membership_transitions", "action_observed_transitions", "kdd152_joint_retained_transitions", "missing_action_exclusions", "original_target_exclusions", "kdd201_removed_transitions", "final_transitions"],
      "properties": {
        "candidate_transitions": {"type": "integer", "minimum": 0},
        "original_target_membership_transitions": {"type": "integer", "minimum": 0},
        "action_observed_transitions": {"type": "integer", "minimum": 0},
        "kdd152_joint_retained_transitions": {"type": "integer", "minimum": 0},
        "missing_action_exclusions": {"type": "integer", "minimum": 0},
        "original_target_exclusions": {"type": "integer", "minimum": 0},
        "kdd201_removed_transitions": {"type": "integer", "minimum": 0},
        "final_transitions": {"type": "integer", "minimum": 0},
        "peep_observed_transitions": {"type": "integer", "minimum": 0},
        "legacy_fio2_observed_transitions": {"type": "integer", "minimum": 0},
        "joint_action_observed_transitions": {"type": "integer", "minimum": 0}
        ,"role_counts": {
          "type": "array", "minItems": 4, "maxItems": 4,
          "prefixItems": [
            {"allOf": [{"$ref": "#/$defs/stage_role"}, {"properties": {"role": {"const": "train"}}}]},
            {"allOf": [{"$ref": "#/$defs/stage_role"}, {"properties": {"role": {"const": "validation"}}}]},
            {"allOf": [{"$ref": "#/$defs/stage_role"}, {"properties": {"role": {"const": "historical_other"}}}]},
            {"allOf": [{"$ref": "#/$defs/stage_role"}, {"properties": {"role": {"const": "all_roles"}}}]}
          ], "items": false
        }
      }
    },
    "stage_role": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "candidate_transitions", "original_target_membership_transitions", "action_observed_transitions", "kdd152_joint_retained_transitions", "kdd201_removed_transitions", "final_transitions"],
      "properties": {
        "role": {"type": "string"},
        "candidate_transitions": {"type": "integer", "minimum": 0},
        "original_target_membership_transitions": {"type": "integer", "minimum": 0},
        "action_observed_transitions": {"type": "integer", "minimum": 0},
        "kdd152_joint_retained_transitions": {"type": "integer", "minimum": 0},
        "kdd201_removed_transitions": {"type": "integer", "minimum": 0},
        "final_transitions": {"type": "integer", "minimum": 0},
        "peep_observed_transitions": {"type": "integer", "minimum": 0},
        "legacy_fio2_observed_transitions": {"type": "integer", "minimum": 0},
        "joint_action_observed_transitions": {"type": "integer", "minimum": 0},
        "missing_action_transitions": {"type": "integer", "minimum": 0}
      }
    },
    "role_summary": {
      "type": "object", "additionalProperties": false,
      "required": ["role", "subjects", "episodes", "decisions", "action_counts", "minimum_horizon", "maximum_horizon", "digests"],
      "properties": {
        "role": {"type": "string"}, "subjects": {"type": "integer", "minimum": 0},
        "episodes": {"type": "integer", "minimum": 0}, "decisions": {"type": "integer", "minimum": 0},
        "action_counts": {"type": "array", "items": {"type": "integer", "minimum": 0}},
        "minimum_horizon": {"type": "integer", "minimum": 0}, "maximum_horizon": {"type": "integer", "minimum": 0},
        "digests": {"$ref": "#/$defs/component_digests"}
      }
    },
    "component_digests": {
      "type": "object", "additionalProperties": false,
      "required": ["feature_digest", "mask_digest", "delta_digest", "raw_imputed_history_digest", "imputed_history_digest", "action_digest", "reward_digest", "reward_mask_digest", "termination_digest", "continuation_digest", "valid_step_digest", "target_digest", "observed_target_mask_digest", "episode_order_digest", "preprocessing_mean_digest", "preprocessing_scale_digest", "transition_order_digest"],
      "properties": {
        "feature_digest": {"$ref": "#/$defs/sha256"}, "mask_digest": {"$ref": "#/$defs/sha256"},
        "delta_digest": {"$ref": "#/$defs/sha256"}, "raw_imputed_history_digest": {"$ref": "#/$defs/sha256"},
        "imputed_history_digest": {"$ref": "#/$defs/sha256"}, "action_digest": {"$ref": "#/$defs/sha256"},
        "reward_digest": {"$ref": "#/$defs/sha256"}, "reward_mask_digest": {"$ref": "#/$defs/sha256"},
        "termination_digest": {"$ref": "#/$defs/sha256"}, "continuation_digest": {"$ref": "#/$defs/sha256"},
        "valid_step_digest": {"$ref": "#/$defs/sha256"}, "target_digest": {"$ref": "#/$defs/sha256"},
        "observed_target_mask_digest": {"$ref": "#/$defs/sha256"}, "episode_order_digest": {"$ref": "#/$defs/sha256"},
        "preprocessing_mean_digest": {"$ref": "#/$defs/sha256"}, "preprocessing_scale_digest": {"$ref": "#/$defs/sha256"},
        "transition_order_digest": {"$ref": "#/$defs/sha256"}
      }
    },
    "sepsis": {"allOf": [{"$ref": "#/$defs/task"}, {"properties": {"task_id": {"const": "sepsis"}, "action_count": {"const": 25}, "action_counts": {"minItems": 25, "maxItems": 25}}}]},
    "respiratory": {"allOf": [{"$ref": "#/$defs/task"}, {"properties": {"task_id": {"const": "respiratory_support"}, "action_count": {"const": 25}, "action_counts": {"minItems": 25, "maxItems": 25}}}]},
    "shock": {"allOf": [{"$ref": "#/$defs/task"}, {"properties": {"task_id": {"const": "shock"}, "action_count": {"const": 25}, "action_counts": {"minItems": 25, "maxItems": 25}}}]},
    "aki": {"allOf": [{"$ref": "#/$defs/task"}, {"properties": {"task_id": {"const": "aki"}, "action_count": {"const": 4}, "action_counts": {"minItems": 4, "maxItems": 4}}}]},
    "heart_failure": {"allOf": [{"$ref": "#/$defs/task"}, {"properties": {"task_id": {"const": "heart_failure"}, "action_count": {"const": 2}, "action_counts": {"minItems": 2, "maxItems": 2}}}]}
  }
}
