{
  "$schema":"https://json-schema.org/draft/2020-12/schema","$id":"https://ehrdyn-icu.org/schemas/kdd235a-world-model-entrant-release-v1.json",
  "title":"KDD235A entrant declaration release view","type":"object","additionalProperties":false,
  "required":["schema_version","entrant_id","command","prediction_type","component_sources","capabilities","deterministic","support_handling_acknowledged"],
  "properties":{"schema_version":{"const":"kdd235a.entrant.v1"},"entrant_id":{"type":"string","pattern":"^[a-z0-9][a-z0-9_.-]{2,63}$"},"command":{"type":"array","minItems":1,"maxItems":16,"items":{"type":"string","minLength":1}},"prediction_type":{"enum":["point","independent_gaussian","gaussian_ensemble"]},"component_sources":{"type":"object","additionalProperties":false,"required":["transition","reward","termination"],"properties":{"transition":{"const":"entrant"},"reward":{"enum":["entrant","benchmark"]},"termination":{"enum":["entrant","benchmark"]}}},"capabilities":{"type":"array","uniqueItems":true,"minItems":3,"items":{"enum":["initialize","fit_or_load","one_step","recursive_rollout","policy_probability","reward","termination"]}},"deterministic":{"const":true},"support_handling_acknowledged":{"const":true},"checkpoint":{"type":"object","additionalProperties":false,"required":["checkpoint_id","source_commit"],"properties":{"checkpoint_id":{"type":"string","minLength":1,"maxLength":128},"source_commit":{"type":"string","pattern":"^[0-9a-f]{7,64}$"}}},"metadata":{"type":"object","additionalProperties":{"type":["string","integer","boolean"]}}}
}
