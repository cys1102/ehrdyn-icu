{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cys1102/ehrdyn-icu/schemas/credentialed_controlled_stop_receipt.schema.json",
  "title": "Current five-task credentialed controlled-stop receipt",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "release", "candidate_status", "failure_code", "runtime", "streaming", "privacy"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "release": {"const": "MIMIC-IV-3.1"},
    "candidate_status": {"const": "controlled_stop"},
    "failure_code": {"enum": ["contract_error", "memory_error", "runtime_error"]},
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["wall_seconds", "maximum_resident_set_size_kib", "temporary_disk_bytes"],
      "properties": {
        "wall_seconds": {"type": "number", "minimum": 0},
        "maximum_resident_set_size_kib": {"type": "integer", "minimum": 0},
        "temporary_disk_bytes": {"type": "integer", "minimum": 0}
      }
    },
    "streaming": {"type": "array", "minItems": 7, "maxItems": 7, "items": {"$ref": "#/$defs/streaming_row"}},
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate_only", "row_level_fields_exported", "private_paths_exported"],
      "properties": {
        "aggregate_only": {"const": true},
        "row_level_fields_exported": {"const": false},
        "private_paths_exported": {"const": false}
      }
    }
  },
  "$defs": {
    "streaming_row": {
      "type": "object",
      "additionalProperties": false,
      "required": ["table", "rows_read", "rows_retained", "chunks_processed", "maximum_retained_rows_per_chunk", "effective_chunk_size", "compression_encoding", "scan_count"],
      "properties": {
        "table": {"enum": ["hosp/labevents", "hosp/microbiologyevents", "hosp/prescriptions", "icu/chartevents", "icu/inputevents", "icu/outputevents", "icu/procedureevents"]},
        "rows_read": {"type": "integer", "minimum": 0},
        "rows_retained": {"type": "integer", "minimum": 0},
        "chunks_processed": {"type": "integer", "minimum": 0},
        "maximum_retained_rows_per_chunk": {"type": "integer", "minimum": 0},
        "effective_chunk_size": {"type": "integer", "minimum": 1},
        "compression_encoding": {"enum": ["csv", "csv_gz", "not_scanned"]},
        "scan_count": {"type": "integer", "minimum": 0}
      }
    }
  }
}
