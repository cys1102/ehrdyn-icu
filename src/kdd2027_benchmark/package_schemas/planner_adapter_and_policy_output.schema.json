{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://ehrdyn-icu.org/schemas/kdd235a-planner-policy-v1.json",
  "title":"KDD235A frozen H4 adapter and policy output",
  "type":"object","additionalProperties":false,
  "required":["schema_version","planner","probabilities"],
  "properties":{
    "schema_version":{"const":"kdd235a.policy.v1"},
    "planner":{"type":"object","additionalProperties":false,"required":["name","horizon","candidates","iterations","elites","smoothing","support_only","execute_first_action","planner_seed"],"properties":{"name":{"const":"H4_support_only_sequence_categorical_CEM"},"horizon":{"const":4},"candidates":{"const":64},"iterations":{"const":3},"elites":{"const":8},"smoothing":{"const":0.2},"support_only":{"const":true},"execute_first_action":{"const":true},"planner_seed":{"const":1903408}}},
    "probabilities":{"type":"array","minItems":1,"items":{"type":"array","minItems":2,"items":{"type":"number","minimum":0,"maximum":1}}}
  }
}
