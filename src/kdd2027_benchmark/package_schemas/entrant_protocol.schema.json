{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ehrdyn-icu.org/schemas/entrant-protocol-v1.json",
  "title": "EHRDyn-ICU isolated entrant declaration",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "entrant_id", "command", "capabilities", "deterministic", "support_handling_acknowledged"],
  "properties": {
    "schema_version": {"const": "kdd215.entrant.v1"},
    "entrant_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9_.-]{2,63}$"},
    "command": {"type": "array", "minItems": 1, "maxItems": 16, "items": {"type": "string", "minLength": 1}},
    "capabilities": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"enum": ["policy_probability", "transition_point", "transition_distribution", "complete_prt"]}
    },
    "deterministic": {"const": true},
    "support_handling_acknowledged": {"const": true}
  }
}
