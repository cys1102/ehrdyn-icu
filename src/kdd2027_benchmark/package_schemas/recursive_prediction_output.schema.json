{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "$id":"https://ehrdyn-icu.org/schemas/kdd235a-recursive-prediction-v1.json",
  "title":"KDD235A recursive prediction output",
  "$defs":{"finite":{"type":"number"},"vector":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/finite"}},"matrix":{"type":"array","minItems":1,"items":{"$ref":"#/$defs/vector"}}},
  "type":"object","additionalProperties":false,
  "required":["schema_version","prediction_type","horizon","mean"],
  "properties":{
    "schema_version":{"const":"kdd235a.prediction.v1"},
    "prediction_type":{"enum":["point","independent_gaussian","gaussian_ensemble"]},
    "horizon":{"type":"integer","minimum":1,"maximum":64},
    "mean":{"$ref":"#/$defs/matrix"},
    "scale":{"$ref":"#/$defs/matrix"},
    "members":{"type":"array","minItems":2,"items":{"type":"object","additionalProperties":false,"required":["mean","scale"],"properties":{"mean":{"$ref":"#/$defs/matrix"},"scale":{"$ref":"#/$defs/matrix"}}}},
    "within_variance":{"$ref":"#/$defs/matrix"},"between_variance":{"$ref":"#/$defs/matrix"},"total_variance":{"$ref":"#/$defs/matrix"},
    "reward":{"type":"array","items":{"type":"number"}},"termination_probability":{"type":"array","items":{"type":"number","minimum":0,"maximum":1}}
  }
}
