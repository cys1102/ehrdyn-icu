{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ehrdyn-icu.org/schemas/aggregate_metrics.schema.json",
  "title": "EHRDyn-ICU aggregate transition metrics",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "benchmark_version", "task_id", "synthetic_fixture",
    "row_count", "episode_count", "feature_count", "overall_rmse",
    "overall_mae", "dynamic_rmse", "sparse_lab_rmse", "gaussian_nll",
    "gaussian_crps", "cov80", "cov90", "width80", "width90",
    "interval_score90", "uncertainty_absolute_error_spearman",
    "action_count_observed", "reward_nonzero_density", "claim_boundary"
  ],
  "properties": {
    "schema_version": {"const": "kdd214-aggregate-metrics-v1"},
    "benchmark_version": {"const": "KDD2027-E060-4H-v1.0.0+KDD089"},
    "task_id": {"type": "string", "minLength": 1},
    "synthetic_fixture": {"type": "boolean"},
    "row_count": {"type": "integer", "minimum": 1},
    "episode_count": {"type": "integer", "minimum": 1},
    "feature_count": {"type": "integer", "minimum": 1},
    "overall_rmse": {"type": "number", "minimum": 0},
    "overall_mae": {"type": "number", "minimum": 0},
    "dynamic_rmse": {"type": "number", "minimum": 0},
    "sparse_lab_rmse": {"type": "number", "minimum": 0},
    "gaussian_nll": {"type": "number"},
    "gaussian_crps": {"type": "number", "minimum": 0},
    "cov80": {"type": "number", "minimum": 0, "maximum": 1},
    "cov90": {"type": "number", "minimum": 0, "maximum": 1},
    "width80": {"type": "number", "minimum": 0},
    "width90": {"type": "number", "minimum": 0},
    "interval_score90": {"type": "number", "minimum": 0},
    "uncertainty_absolute_error_spearman": {"type": "number", "minimum": -1, "maximum": 1},
    "action_count_observed": {"type": "integer", "minimum": 1},
    "reward_nonzero_density": {"type": "number", "minimum": 0, "maximum": 1},
    "claim_boundary": {"type": "string", "minLength": 1},
    "baseline": {"enum": ["persistence", "previous_window"]}
  }
}
