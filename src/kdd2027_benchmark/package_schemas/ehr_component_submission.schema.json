{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ehrdyn-icu.org/schemas/ehr-component-submission-v2.0.0.json",
  "title": "Canonical-v2 local EHR component prediction submission",
  "$defs": {
    "finite": {"type": "number"},
    "feature_vector": {
      "type": "array",
      "minItems": 33,
      "maxItems": 33,
      "items": {"$ref": "#/$defs/finite"}
    },
    "mask_vector": {
      "type": "array",
      "minItems": 33,
      "maxItems": 33,
      "items": {"type": "integer", "enum": [0, 1]}
    },
    "member": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mean", "scale"],
      "properties": {
        "mean": {"$ref": "#/$defs/feature_vector"},
        "scale": {
          "type": "array",
          "minItems": 33,
          "maxItems": 33,
          "items": {"type": "number", "exclusiveMinimum": 0}
        }
      }
    },
    "record": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "horizon_step", "target", "target_mask", "mean",
        "termination_target", "termination_probability", "action",
        "action_supported", "behavior_probability", "target_probability"
      ],
      "properties": {
        "horizon_step": {"type": "integer", "minimum": 1, "maximum": 11},
        "target": {"$ref": "#/$defs/feature_vector"},
        "target_mask": {"$ref": "#/$defs/mask_vector"},
        "mean": {"$ref": "#/$defs/feature_vector"},
        "scale": {
          "type": "array",
          "minItems": 33,
          "maxItems": 33,
          "items": {"type": "number", "exclusiveMinimum": 0}
        },
        "members": {
          "type": "array",
          "minItems": 2,
          "items": {"$ref": "#/$defs/member"}
        },
        "termination_target": {"type": "integer", "enum": [0, 1]},
        "termination_probability": {"type": "number", "minimum": 0, "maximum": 1},
        "action": {"type": "integer", "minimum": 0},
        "action_supported": {"type": "boolean"},
        "behavior_probability": {"type": "number", "exclusiveMinimum": 0, "maximum": 1},
        "target_probability": {"type": "number", "minimum": 0, "maximum": 1}
      }
    }
  },
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version", "benchmark_version", "evaluator_version", "task_id",
    "prediction_type", "synthetic", "aggregate_context", "records"
  ],
  "properties": {
    "schema_version": {"const": "ehr-component-submission-v2.0.0"},
    "benchmark_version": {"const": "ehrdyn-icu-canonical-v2.0.0"},
    "evaluator_version": {"const": "ehr-component-scorer-v2.0.0"},
    "task_id": {
      "enum": ["sepsis", "respiratory_support", "shock", "aki", "heart_failure"]
    },
    "prediction_type": {
      "enum": ["point", "independent_gaussian", "gaussian_ensemble"]
    },
    "synthetic": {"type": "boolean"},
    "aggregate_context": {
      "type": "object",
      "additionalProperties": false,
      "required": ["distinct_subjects", "episodes"],
      "properties": {
        "distinct_subjects": {"type": "integer", "minimum": 1},
        "episodes": {"type": "integer", "minimum": 1}
      }
    },
    "records": {
      "type": "array",
      "minItems": 1,
      "items": {"$ref": "#/$defs/record"}
    }
  }
}
