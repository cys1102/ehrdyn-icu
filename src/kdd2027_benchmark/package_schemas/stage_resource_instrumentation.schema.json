{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/cys1102/ehrdyn-icu/schemas/stage_resource_instrumentation.schema.json",
  "title": "Aggregate-only constructor stage resource instrumentation",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "status", "stages", "privacy"],
  "properties": {
    "schema_version": {"const": "1.0.0"},
    "status": {"enum": ["complete", "controlled_stop"]},
    "stages": {
      "type": "array",
      "items": {"$ref": "#/$defs/stage"}
    },
    "privacy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["aggregate_only", "row_level_fields_exported", "private_paths_exported"],
      "properties": {
        "aggregate_only": {"const": true},
        "row_level_fields_exported": {"const": false},
        "private_paths_exported": {"const": false}
      }
    }
  },
  "$defs": {
    "stage": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "stage", "elapsed_seconds", "rows_read", "rows_retained", "chunk_size",
        "temporary_disk_high_water_bytes", "rss_entry_kib", "rss_exit_kib", "peak_rss_kib"
      ],
      "properties": {
        "stage": {"type": "string", "pattern": "^[A-Za-z0-9:/_-]+$"},
        "elapsed_seconds": {"type": "number", "minimum": 0},
        "rows_read": {"type": "integer", "minimum": 0},
        "rows_retained": {"type": "integer", "minimum": 0},
        "chunk_size": {"type": "integer", "minimum": 0},
        "temporary_disk_high_water_bytes": {"type": "integer", "minimum": 0},
        "rss_entry_kib": {"type": "integer", "minimum": 0},
        "rss_exit_kib": {"type": "integer", "minimum": 0},
        "peak_rss_kib": {"type": "integer", "minimum": 0}
      }
    }
  }
}
